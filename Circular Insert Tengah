#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node* head = NULL;

    Node* node1 = new Node{10, NULL};
    Node* node2 = new Node{30, NULL};

    head = node1;
    node1->next = node2;
    node2->next = head;

    Node* current = head;
    do {
        if (current->data == 10) {
            Node* newNode = new Node;
            newNode->data = 20;
            newNode->next = current->next;
            current->next = newNode;
            break;
        }
        current = current->next;
    } while (current != head);

    Node* temp = head;
    do {
        cout << temp->data << " -> ";
        temp = temp->next;
    } while (temp != head);
    cout << "(kembali ke head)" << endl;

    return 0;
}
