#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node* head = NULL;

    Node* node1 = new Node;
    node1->data = 20;
    node1->next = NULL;
    head = node1;

    Node* newNode = new Node;
    newNode->data = 10;
    newNode->next = head;
    head = newNode;

    Node* temp = head;
    while (temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }
    cout << "NULL" << endl;

    return 0;
}
