#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node* node1 = new Node{10, NULL};
    Node* node2 = new Node{20, NULL};
    Node* node3 = new Node{30, NULL};

    Node* head = node1;
    node1->next = node2;
    node2->next = node3;
    node3->next = head;

    Node* prev = NULL;
    Node* current = head;

    while (current->next != head) {
        prev = current;
        current = current->next;
    }

    prev->next = head;
    delete current;

    Node* temp = head;
    do {
        cout << temp->data << " -> ";
        temp = temp->next;
    } while (temp != head);
    cout << "(kembali ke head)" << endl;

    return 0;
}
