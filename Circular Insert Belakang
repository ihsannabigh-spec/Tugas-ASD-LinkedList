#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node* head = NULL;

    Node* node1 = new Node{10, NULL};
    Node* node2 = new Node{20, NULL};

    head = node1;
    node1->next = node2;
    node2->next = head;

    Node* newNode = new Node;
    newNode->data = 30;

    Node* tail = head;
    while (tail->next != head) {
        tail = tail->next;
    }

    tail->next = newNode;
    newNode->next = head;

    Node* temp = head;
    do {
        cout << temp->data << " -> ";
        temp = temp->next;
    } while (temp != head);
    cout << "(kembali ke head)" << endl;

    return 0;
}
