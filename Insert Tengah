#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node* head = NULL;

    Node* node1 = new Node{10, NULL};
    Node* node2 = new Node{30, NULL};

    head = node1;
    node1->next = node2;

    Node* current = head;
    while (current != NULL && current->data != 10) {
        current = current->next;
    }

    if (current != NULL) {
        Node* newNode = new Node;
        newNode->data = 20;
        newNode->next = current->next;
        current->next = newNode;
    }

    Node* temp = head;
    while (temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }
    cout << "NULL" << endl;

    return 0;
}
